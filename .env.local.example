# Sanity — copy to .env.local and fill in from sanity.io/manage
# Without these, the Resources Hub serves bundled local content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01

# Optional — only needed for draft/preview content (keep secret, server-only)
SANITY_API_READ_TOKEN=

# Canonical site origin (sitemap, robots, RSS, OG)
NEXT_PUBLIC_SITE_URL=https://accountclerks.com

# Contact — scheduling
NEXT_PUBLIC_CALENDLY_URL=

# Contact — email notifications (Resend)
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=hello@accountclerks.com
CONTACT_FROM_EMAIL=ACCOUNTCLERKS <noreply@accountclerks.com>

# Contact — CRM (use ONE: a generic webhook OR HubSpot)
CRM_WEBHOOK_URL=
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Analytics (both optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=   # cookieless — loads without consent
NEXT_PUBLIC_GA_ID=              # cookie-based — loads only after consent
